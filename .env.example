# =============================================================================
# IronFreight – Environment variables (copy to .env.local and fill in values)
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required for auth + database)
# Get these from: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------
# Project URL (e.g. https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon (public) key – safe for browser; used by the Next.js client
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key – server-only; full access, never expose in the browser
# Optional: use for admin scripts or server-side Supabase client
# SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Maps (for geofence display, chain-of-custody map, driver location)
# Use one of the two below when you add embedded maps. Geofence data is already
# in Supabase (loads.origin_geofence_*, custody_events.lat/lng); a map key
# is needed to render the map tiles and optional geofence circles.
# -----------------------------------------------------------------------------
# Mapbox – get at: https://account.mapbox.com/access-tokens/
# NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_public_token_here

# Google Maps – get at: Google Cloud Console → APIs & Services → Credentials
# Needed if you use Google Maps JS API for embedded maps or the driver "Open in maps" link in production.
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Optional (uncomment and set if you use these)
# -----------------------------------------------------------------------------
# Site URL for auth redirects (e.g. https://iron-freight.netlify.app or http://localhost:3000)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email (SendGrid) – required for invites and quote emails.
# Invites: info@getironfreight.com. Quote: billing@. Driver verification: verify@getironfreight.com.
# Verify these senders (or your domain) in SendGrid Sender Authentication; otherwise you may get 403 Forbidden.
# To reduce Gmail Promotions/Spam: set up Domain Authentication in SendGrid (SPF + DKIM + DMARC for getironfreight.com).
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=noreply@getironfreight.com

# -----------------------------------------------------------------------------
# Stripe (payments)
# Dashboard: https://dashboard.stripe.com → API keys, Products, Webhooks
# -----------------------------------------------------------------------------
# Publishable key – safe for browser (e.g. Stripe Checkout redirect, Elements)
# STRIPE_PUBLISHABLE_KEY=pk_test_...

# Secret key – server-only; used to create Checkout sessions, read customers, handle webhooks
# STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret – from Stripe Dashboard → Developers → Webhooks → Add endpoint
# Endpoint URL: https://your-domain.com/api/stripe/webhook
# STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs – create in Stripe: one Product per role (Broker, Carrier, Shipper), each with Monthly + Yearly prices.
# Subscribe links use these: /subscribe/broker/monthly, /subscribe/carrier/yearly, etc. (7-day trial applied in API)
# STRIPE_PRICE_BROKER_MONTHLY=price_...
# STRIPE_PRICE_BROKER_YEARLY=price_...
# STRIPE_PRICE_CARRIER_MONTHLY=price_...
# STRIPE_PRICE_CARRIER_YEARLY=price_...
# STRIPE_PRICE_SHIPPER_MONTHLY=price_...
# STRIPE_PRICE_SHIPPER_YEARLY=price_...

# Broker $10/verified load – monthly metered price (so yearly brokers get verification charges monthly, not at year-end)
# Create in Stripe: Product "IronFreight Broker Verification" (or add to Broker product) → Price: metered, $10/unit, recurring monthly
# STRIPE_PRICE_BROKER_VERIFICATION_METERED=price_...

# -----------------------------------------------------------------------------
# FMCSA (carrier/broker lookup by MC or DOT)
# Get a WebKey at: https://mobile.fmcsa.dot.gov/QCDevsite/ (Login.gov)
# FMCSA_WEB_KEY=your_web_key_here

# -----------------------------------------------------------------------------
# Desktop app installers (optional – for /download page)
# After building installers (desktop/README.md), host the .exe and .dmg and set:
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_DOWNLOAD_WIN_URL=https://github.com/your-org/iron-freight/releases/download/v1.0.0/IronFreight-Setup-1.0.0.exe
# NEXT_PUBLIC_DOWNLOAD_MAC_URL=https://github.com/your-org/iron-freight/releases/download/v1.0.0/IronFreight-1.0.0.dmg

# Investor page video: YouTube/Vimeo embed URL (https://...) or leave unset to use local file public/videos/investor-overview.mp4
# NEXT_PUBLIC_INVESTOR_VIDEO_URL=https://www.youtube.com/embed/your-video-id

# -----------------------------------------------------------------------------
# Contact (reference only – no secrets)
# getironfreight.com
# Support@getironfreight.com | Billing@getironfreight.com | Verify@getironfreight.com
# Disputes@getironfreight.com | Vetting@getironfreight.com | Info@getironfreight.com
# -----------------------------------------------------------------------------
